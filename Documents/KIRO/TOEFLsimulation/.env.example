# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose — required environment variables
#
# Copy this file to .env and fill in real values before running docker-compose.
# This file is safe to commit; .env must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password (used by both the postgres service and the backend).
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=<generate_a_strong_password>

# JWT signing secret (minimum 32 characters, ideally 64+).
# Generate: openssl rand -hex 64
JWT_SECRET=<generate_with_openssl_rand_hex_64>

# Google Gemini API key — obtain from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed CORS origins (optional, defaults shown below).
ALLOWED_ORIGINS=http://localhost:80,http://localhost:3000

# Public URL of the frontend (optional).
FRONTEND_URL=http://localhost:80
