# Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database Configuration
# Replace <your_db_password> with the password you chose when starting Postgres.
DATABASE_URL=postgresql://postgres:<your_db_password>@localhost:5432/toefl_simulator
DB_HOST=localhost
DB_PORT=5432
DB_NAME=toefl_simulator
DB_USER=postgres
DB_PASSWORD=<your_db_password>
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_DURATION_MINUTES=90

# IRT Configuration
IRT_EASY_THRESHOLD=-0.8
IRT_HARD_THRESHOLD=0.8
MAX_LIKELIHOOD_ITERATIONS=50
CONVERGENCE_CRITERION=0.001
